{
  "name": "@galileyo/cron",
  "type": "module",
  "scripts": {
    "build": "pnpm with-env tsc --outDir dist",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "pnpm with-env tsx watch src/index.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env node dist/index.js",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@galileyo/db": "workspace:*",
    "@galileyo/queue": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "date-fns": "^4.1.0",
    "jiti": "catalog:",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@galileyo/eslint-config": "workspace:*",
    "@galileyo/prettier-config": "workspace:*",
    "@galileyo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "^9.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.20.6",
    "typescript": "catalog:"
  },
  "prettier": "@galileyo/prettier-config"
}
