# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your mysql database.
DATABASE_URL="mysql://galileoUser:password@localhost/Galileyo_Prod"

NEXT_PUBLIC_API_URL=http://localhost:22080/v1

# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# Admin -> frontend user impersonation
IMPERSONATION_SHARED_SECRET=
IMPERSONATION_TOKEN_TTL_SECONDS=60

# Email delivery
# Set RESEND_API_KEY for production email delivery via Resend.
# EMAIL_FROM must use a sender/domain verified in the Resend account.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=no-reply@galileyo.com
REGISTRATION_EMAIL_URL=https://galileyo.com/studios
REGISTRATION_EMAIL_SUBJECT="Finish your Galileyo Studios registration"
# Optional SMTP fallback used when RESEND_API_KEY is not set.
EMAIL_IS_SECURE=false
EMAIL_HOST=localhost
EMAIL_PORT=1026
EMAIL_USER=
EMAIL_PASSWORD=

# VAPID keys for push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Growthbook for feature flags
GROWTHBOOK_CLIENT_KEY=
GROWTHBOOK_API_HOST=

# Zyte API key for scraping
ZYTE_API_KEY=

# Influencer impersonation API key for impersonating influencers
INFLUENCER_IMPERSONATION_API_KEY=

# DisasterAware username and password for accessing the API
DISASTERAWARE_USERNAME=
DISASTERAWARE_PASSWORD=

NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ID=f49637f6
NEXT_PUBLIC_WEBHOOKS_ENABLED=false
NEXT_PUBLIC_WS_PORT=3001
NEXT_PUBLIC_AD_SPACING=5
NEXT_PUBLIC_UPGRADE_AD_SPACING=1
NEXT_PUBLIC_VIDEO_FEED_INITIAL_LIMIT=1
NEXT_PUBLIC_VIDEO_FEED_PREFETCH_AHEAD=1
NEXT_PUBLIC_PREVIEW_ENABLED=false
NEXT_PUBLIC_VIDEO_PROXY_ENABLED=true
PREVIEW_PORT=3500
PREVIEW_SERVER_URL=http://localhost:3500

# ============================================================================
# Video Streaming Provider Configuration
# ============================================================================
# Choose ONE video provider by setting its ENABLE flag to "true"
# Provider priority: Bunny > Mux > S3-only (no transcoding)

# ----------------------------------------------------------------------------
# Bunny.net Stream (https://docs.bunny.net/stream)
# Recommended for cost-effective video streaming with global CDN
# ----------------------------------------------------------------------------
ENABLE_BUNNY=false
# Your Bunny Stream library API key (found in Video Library > API)
BUNNY_STREAM_API_KEY=
# Your Bunny Stream library ID (found in Video Library settings)
BUNNY_STREAM_LIBRARY_ID=
# Optional: Custom CDN hostname (e.g., vz-abc123.b-cdn.net)
# If not set, will be auto-generated from library ID
BUNNY_STREAM_CDN_HOSTNAME=
# Optional: Webhook secret for verifying Bunny webhook callbacks
BUNNY_WEBHOOK_SECRET=
# Upload mode: "true" for TUS resumable uploads, "false" for HTTP API
# TUS (default): Better for large files, resumable, requires tus-js-client
# HTTP: Simpler, uploads via server proxy, not resumable
# @see https://docs.bunny.net/stream/tus-resumable-uploads
# @see https://docs.bunny.net/stream/http-api
BUNNY_USE_TUS=true

# ----------------------------------------------------------------------------
# Mux Video (https://mux.com)
# Premium video streaming with advanced analytics
# ----------------------------------------------------------------------------
ENABLE_MUX=false
# Your Mux API token ID
MUX_TOKEN_ID=
# Your Mux API token secret
MUX_TOKEN_SECRET=
# Optional: Webhook signing secret for Mux webhooks
MUX_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# S3 Storage (always required as backup/fallback)
# ----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=public-uploads
S3_FORCE_PATH_STYLE=true

# ============================================================================
# Galileyo Studios
# ============================================================================
# Trailer URL shown as the hero background on /studios. Leave blank for the
# gradient fallback.
NEXT_PUBLIC_EPISODE_1_TRAILER_URL=
# Cloudflare-served public demo/video URL used by the marketing phone mockups.
# Prefer a Cloudflare Stream HLS manifest URL; MP4 delivery also works.
NEXT_PUBLIC_GALILEYO_MOBILE_VIDEO_URL=
# ISO-8601 timestamp the countdown ticks toward. Leave blank for a 30-day
# rolling fallback.
NEXT_PUBLIC_NEXT_EPISODE_DATE=
# Studios film funding progress (USD). Used by the producer tier preview.
NEXT_PUBLIC_STUDIOS_FUNDING_FILM_CURRENT=0
NEXT_PUBLIC_STUDIOS_FUNDING_FILM_TARGET=3500000
# Studios game funding progress (USD). Used by the game producer card.
NEXT_PUBLIC_STUDIOS_FUNDING_GAME_CURRENT=0
NEXT_PUBLIC_STUDIOS_FUNDING_GAME_TARGET=1000000
# Cloudflare Stream HLS URL for Episode 1 (used by the watch player in Phase 2).
NEXT_PUBLIC_EPISODE_1_HLS_URL=
# Server-side secret used to HMAC-sign the studios_unlock cookie.
# Generate with: openssl rand -base64 32
STUDIOS_UNLOCK_SECRET=replace-with-random-32-char-string
# Comma-separated recipients for sponsor, affiliate, and producer inquiries.
STUDIOS_SPONSOR_INQUIRY_TO=brett@galileyo.com

# --- Galileyo Studios: Cloudflare Stream + Images (Phase 1) ---
# All optional. Leave empty to keep local placeholder media and the
# NEXT_PUBLIC_EPISODE_1_HLS_URL fallback working.
# Cloudflare account that owns the Stream + Images resources.
CLOUDFLARE_ACCOUNT_ID=
# Stream API token (used by future upload/admin flows; not required for playback).
CLOUDFLARE_STREAM_API_TOKEN=
# Customer subdomain for HLS manifests, e.g. customer-xxxx.cloudflarestream.com
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=
# Signing key ID and PEM private key for RS256 signed tokens on paid episodes.
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_PEM=
# Images API token (used by future upload/admin flows).
CLOUDFLARE_IMAGES_API_TOKEN=
# Public account hash for image delivery URLs (imagedelivery.net/{hash}/...).
NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH=

# --- Galileyo Studios: Stripe (Phase 2) ---
# All optional. Leave NEXT_PUBLIC_STRIPE_ENABLED=false to keep every purchase
# CTA in its "coming this week" / email-capture state until keys are live.
# Stripe secret key (sk_test_... or sk_live_...).
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) from the Stripe dashboard webhook config.
STRIPE_WEBHOOK_SECRET=
# Flip to true only after running scripts/studios-stripe-setup.ts so price IDs
# exist in the studios_setting table.
NEXT_PUBLIC_STRIPE_ENABLED=false
