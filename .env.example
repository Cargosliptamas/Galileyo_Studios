# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your mysql database.
DATABASE_URL="mysql://galileoUser:password@localhost/Galileyo_Prod"

NEXT_PUBLIC_API_URL=http://localhost:22080/v1

# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# VAPID keys for push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Growthbook for feature flags
GROWTHBOOK_CLIENT_KEY=
GROWTHBOOK_API_HOST=

# Zyte API key for scraping
ZYTE_API_KEY=

# Influencer impersonation API key for impersonating influencers
INFLUENCER_IMPERSONATION_API_KEY=

# DisasterAware username and password for accessing the API
DISASTERAWARE_USERNAME=
DISASTERAWARE_PASSWORD=

NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ID=f49637f6
NEXT_PUBLIC_WEBHOOKS_ENABLED=false
NEXT_PUBLIC_WS_PORT=3001
NEXT_PUBLIC_AD_SPACING=5
NEXT_PUBLIC_UPGRADE_AD_SPACING=1
NEXT_PUBLIC_VIDEO_FEED_INITIAL_LIMIT=1
NEXT_PUBLIC_VIDEO_FEED_PREFETCH_AHEAD=1
NEXT_PUBLIC_PREVIEW_ENABLED=false
NEXT_PUBLIC_VIDEO_PROXY_ENABLED=true
PREVIEW_PORT=3500
PREVIEW_SERVER_URL=http://localhost:3500

# ============================================================================
# Video Streaming Provider Configuration
# ============================================================================
# Choose ONE video provider by setting its ENABLE flag to "true"
# Provider priority: Bunny > Mux > S3-only (no transcoding)

# ----------------------------------------------------------------------------
# Bunny.net Stream (https://docs.bunny.net/stream)
# Recommended for cost-effective video streaming with global CDN
# ----------------------------------------------------------------------------
ENABLE_BUNNY=false
# Your Bunny Stream library API key (found in Video Library > API)
BUNNY_STREAM_API_KEY=
# Your Bunny Stream library ID (found in Video Library settings)
BUNNY_STREAM_LIBRARY_ID=
# Optional: Custom CDN hostname (e.g., vz-abc123.b-cdn.net)
# If not set, will be auto-generated from library ID
BUNNY_STREAM_CDN_HOSTNAME=
# Optional: Webhook secret for verifying Bunny webhook callbacks
BUNNY_WEBHOOK_SECRET=
# Upload mode: "true" for TUS resumable uploads, "false" for HTTP API
# TUS (default): Better for large files, resumable, requires tus-js-client
# HTTP: Simpler, uploads via server proxy, not resumable
# @see https://docs.bunny.net/stream/tus-resumable-uploads
# @see https://docs.bunny.net/stream/http-api
BUNNY_USE_TUS=true

# ----------------------------------------------------------------------------
# Mux Video (https://mux.com)
# Premium video streaming with advanced analytics
# ----------------------------------------------------------------------------
ENABLE_MUX=false
# Your Mux API token ID
MUX_TOKEN_ID=
# Your Mux API token secret
MUX_TOKEN_SECRET=
# Optional: Webhook signing secret for Mux webhooks
MUX_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# S3 Storage (always required as backup/fallback)
# ----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=public-uploads
S3_FORCE_PATH_STYLE=true
