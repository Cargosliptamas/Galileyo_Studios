{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "pull": {
      "cache": false,
      "interactive": true
    },
    "genm": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    }
  },
  "globalEnv": [
    "DATABASE_URL",
    "AUTH_DISCORD_ID",
    "AUTH_DISCORD_SECRET",
    "AUTH_REDIRECT_PROXY_URL",
    "AUTH_SECRET",
    "DISASTERAWARE_USERNAME",
    "DISASTERAWARE_PASSWORD",
    "EMAIL_IS_SECURE",
    "EMAIL_HOST",
    "EMAIL_PORT",
    "EMAIL_USER",
    "EMAIL_PASSWORD",
    "EMAIL_FROM",
    "NEXT_PUBLIC_API_URL",
    "PORT",
    "ZYTE_API_KEY",
    "REDIS_URL",
    "NEXT_PUBLIC_WS_PORT",
    "NEXT_PUBLIC_APP_URL",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_BUCKET_NAME",
    "S3_PUBLIC_URL",
    "S3_FORCE_PATH_STYLE",
    "ENABLE_MUX",
    "MUX_TOKEN_ID",
    "MUX_TOKEN_SECRET",
    "MUX_WEBHOOK_SECRET",
    "ENABLE_BUNNY",
    "BUNNY_STREAM_API_KEY",
    "BUNNY_STREAM_LIBRARY_ID",
    "BUNNY_STREAM_CDN_HOSTNAME",
    "BUNNY_USE_TUS",
    "NEXT_PUBLIC_EPISODE_1_TRAILER_URL",
    "NEXT_PUBLIC_NEXT_EPISODE_DATE",
    "NEXT_PUBLIC_STUDIOS_FUNDING_FILM_CURRENT",
    "NEXT_PUBLIC_STUDIOS_FUNDING_FILM_TARGET",
    "NEXT_PUBLIC_STUDIOS_FUNDING_GAME_CURRENT",
    "NEXT_PUBLIC_STUDIOS_FUNDING_GAME_TARGET",
    "NEXT_PUBLIC_EPISODE_1_HLS_URL",
    "STUDIOS_UNLOCK_SECRET",
    "CLOUDFLARE_ACCOUNT_ID",
    "CLOUDFLARE_STREAM_API_TOKEN",
    "CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN",
    "CLOUDFLARE_STREAM_SIGNING_KEY_ID",
    "CLOUDFLARE_STREAM_SIGNING_KEY_PEM",
    "CLOUDFLARE_IMAGES_API_TOKEN",
    "NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "NEXT_PUBLIC_STRIPE_ENABLED"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event"
  ]
}
