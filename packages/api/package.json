{
  "name": "@galileyo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./video": {
      "types": "./dist/src/video.d.ts",
      "default": "./src/video.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "@date-fns/utc": "^2.1.1",
    "@galileyo/auth": "workspace:*",
    "@galileyo/db": "workspace:*",
    "@galileyo/utils": "workspace:*",
    "@galileyo/validators": "workspace:*",
    "@mux/mux-node": "^9.0.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@trpc/server": "catalog:",
    "date-fns": "^4.1.0",
    "ioredis": "^5.8.2",
    "nanoid": "^5.1.6",
    "openmeteo": "^1.2.2",
    "simple-peer": "catalog:",
    "superjson": "2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@galileyo/eslint-config": "workspace:*",
    "@galileyo/prettier-config": "workspace:*",
    "@galileyo/tsconfig": "workspace:*",
    "@types/simple-peer": "^9.11.9",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@galileyo/prettier-config"
}
