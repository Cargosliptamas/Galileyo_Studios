      "default": "./src/feed.ts"
    },
    "./alert": {
      "types": "./dist/alert.d.ts",
      "default": "./src/alert.ts"
    },
    "./bookmark": {
      "types": "./dist/bookmark.d.ts",
      "default": "./src/bookmark.ts"
    },
    "./payment": {
      "types": "./dist/payment.d.ts",
      "default": "./src/payment.ts"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "default": "./src/profile.ts"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "default": "./src/search.ts"
    },
    "./scraping": {
      "types": "./dist/scraping.d.ts",
      "default": "./src/scraping.ts"
    },
